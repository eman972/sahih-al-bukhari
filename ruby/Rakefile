# frozen_string_literal: true

require 'bundler/gem_tasks'

# ── Test task ─────────────────────────────────────────────────────────────────
# FIX: Ruby 4.0 removed test/unit from stdlib — it is now the 'test-unit' gem.
# We require it explicitly here so rake/testtask can find it.
require 'test/unit'
require 'rake/testtask'

Rake::TestTask.new(:test) do |t|
  t.libs << 'lib'
  t.test_files = FileList['test/**/*_test.rb', 'test/**/test_*.rb']
  t.verbose    = true
end

# ── RSpec task (only if rspec gem is available)
begin
  require 'rspec/core/rake_task'
  RSpec::Core::RakeTask.new(:spec)
rescue LoadError
  task :spec do
    warn 'rspec gem not available — run: gem install rspec'
  end
end

# ── YARD docs (only if yard gem is available)
begin
  require 'yard'
  YARD::Rake::YardocTask.new(:yard) do |t|
    t.files   = ['lib/**/*.rb', '-', 'README.md']
    t.options = ['--markup', 'markdown']
  end
rescue LoadError
  task :yard do
    warn 'yard gem not available — run: gem install yard'
  end
end

task default: :test

# ── Custom gem tasks ──────────────────────────────────────────────────────────
namespace :bukhari do
  desc 'Run basic functionality smoke-test'
  task :test_basic do
    $LOAD_PATH.unshift File.join(__dir__, 'lib')
    require 'sahih_al_bukhari'

    puts 'Testing basic functionality…'
    b = SahihAlBukhari::Bukhari.new
    puts "  ✓ Total hadiths : #{b.length}"
    puts "  ✓ Total chapters: #{b.chapters.length}"

    h = b.get(1)
    puts "  ✓ get(1)         : Hadith ##{h.id}"

    results = b.search('prayer')
    puts "  ✓ search(prayer) : #{results.length} results"

    rnd = b.get_random
    puts "  ✓ get_random()   : Hadith ##{rnd.id}"

    puts 'All basic checks passed!'
  end

  desc 'Test the CLI binary'
  task :test_cli do
    cli = File.join(__dir__, 'bin', 'bukhari')
    sh "ruby -I lib #{cli} --version"
    sh "ruby -I lib #{cli} --help"
    sh "ruby -I lib #{cli} -n 1"
    sh "ruby -I lib #{cli} -r"
  end

  desc 'Download / verify data files are in place'
  task :prepare_data do
    $LOAD_PATH.unshift File.join(__dir__, 'lib')
    require 'sahih_al_bukhari'
    _b = SahihAlBukhari::Bukhari.new   # triggers CDN download if needed
    puts 'Data files are ready.'
  end
end
