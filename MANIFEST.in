# MANIFEST.in — controls what gets included in the Python sdist

# ── Include shared data files ────────────────────────────────────────────────
include bin/bukhari.json
recursive-include chapters *.json

# ── Include Python source ────────────────────────────────────────────────────
recursive-include python *.py

# ── Exclude Docs ────────────────────────────────────────────────────
prune docs


# ── Include standard text files ──────────────────────────────────────────────
include README.md
include LICENSE
include pyproject.toml
include CHANGELOG.md

# ── Exclude ALL JavaScript / npm files ───────────────────────────────────────
exclude package.json
exclude package-lock.json
exclude .npmignore
exclude .gitignore
prune src
prune scripts
prune types
prune examples/
prune examples
prune examples/node-commonjs
prune examples/node-esm
prune examples/react
prune node_modules
prune .github/workflows
