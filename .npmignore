# .npmignore — excludes from `npm publish`

# ── Python package ───────────────────────────────────────────────────────────
python/
*.py
pyproject.toml
MANIFEST.in
setup.py
setup.cfg

# ── Python build artefacts ───────────────────────────────────────────────────
dist/
*.egg-info/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# ── docs ───────────────────────────────────────────────────────────
docs
docs/

# ── examples ───────────────────────────────────────────────────────────
examples/
examples
examples/flask/
examples/express/

# ── Dev / CI ──────────────────────────────────────────────────────────────────
.git/
.github/
.gitignore
*.log
.DS_Store
.env

# ── JS build inputs (not needed by consumers) ────────────────────────────────
scripts/
package-lock.json
CHANGELOG.md
CONTRIBUTING.md
docs/
tests/
